# GitHub 存储配置
# 复制此文件为 .env 并填入真实值（.env 不提交到 git）

# GitHub Personal Access Token (需要 repo 或 Contents read/write 权限)
# 创建地址: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub 仓库信息（存放 architecture.json 的仓库）
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name

# 数据文件在仓库中的路径（默认 data/architecture.json）
GITHUB_FILE_PATH=data/architecture.json

# 服务端口（默认 3001）
PORT=3001
